# ===== Acesso ao app (Fase 3) =====
# Senha para entrar no criador. Defina um valor forte na Vercel.
CARROSSEL_PASSWORD=

# ===== IA (Fase 2) — provider trocável =====
# Qual provider usar para "Gerar novo com IA": anthropic | google | openai
AI_PROVIDER=anthropic

# Preencha apenas a chave do provider que for usar.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
