# ===== Acesso ao app (Fase 3) =====
# Senha para entrar no criador. Defina um valor forte na Vercel.
CARROSSEL_PASSWORD=

# ===== IA (Fase B) — provider trocável =====
# Qual provider usar nas gerações por IA: anthropic | google | openai | mock
#   mock = teste sem credencial (gera conteúdo offline derivado do banco;
#          não é IA real, serve pra exercitar o fluxo enquanto não há chave)
AI_PROVIDER=anthropic

# Preencha apenas a chave do provider que for usar (mock não precisa de chave).
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Opcional: sobrepõe o modelo padrão do provider ativo.
# Padrões: anthropic=claude-sonnet-4-6 · google=gemini-2.5-flash · openai=gpt-5-mini
AI_MODEL=
